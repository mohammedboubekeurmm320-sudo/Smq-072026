# ============================================================================
# QMS ISO 13485 Pro — Environment Variables
# ============================================================================
# Pour Vercel : copier ces variables dans Settings → Environment Variables
# Pour local : copier ce fichier en .env et remplir les valeurs
# ============================================================================

# --- Base de données Supabase (OBLIGATOIRE) ---
# Connection pooler URL (recommandé pour Vercel/cloud) :
#   Supabase Dashboard → Settings → Database → Connection string → Connection pooling
#   Format : postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Session (OBLIGATOIRE) ---
# Clé secrète pour signer les cookies de session — changer en production !
SESSION_SECRET=

# --- Supabase Client (OPTIONNEL — uniquement si vous utilisez le client JS Supabase) ---
# NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key